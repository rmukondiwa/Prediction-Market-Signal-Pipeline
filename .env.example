# Kalshi API credentials
KALSHI_API_KEY_ID=your-api-key-id-here

# Private key — choose ONE of the two options below:

# Option 1 (recommended): paste the raw PEM key content directly.
# Replace literal newlines with \n so it fits on one line.
# KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# Option 2: point to your .pem or .txt file containing the key.
# KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private_key.txt

# Kalshi endpoints (defaults shown — omit to use production)
# KALSHI_WS_URL=wss://trading-api.kalshi.com/trade-api/ws/v2
# KALSHI_REST_URL=https://trading-api.kalshi.com/trade-api/v2

# Comma-separated list of market tickers to subscribe to
KALSHI_MARKET_TICKERS=INXD-23DEC31-B4000,KXBTCD-23DEC31-B40000

# Channels to subscribe to (default: ticker,orderbook_delta,trade)
# KALSHI_CHANNELS=ticker,orderbook_delta,trade

# Reconnect settings
# KALSHI_RECONNECT_ATTEMPTS=10
# KALSHI_RECONNECT_BASE_DELAY=1.0
# KALSHI_RECONNECT_MAX_DELAY=60.0
# KALSHI_PING_INTERVAL=20

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Redis stream names (defaults shown)
# REDIS_MARKET_EVENTS_STREAM=market_events
# REDIS_TRADE_EVENTS_STREAM=trade_events
# REDIS_ORDERBOOK_EVENTS_STREAM=orderbook_events
# REDIS_STREAM_MAX_LEN=100000
